rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: potlucks
    // Document ID: guid
    // Fields:
    //   - id: string (required)
    //   - title: string (required)
    //   - ownerId: string (required, immutable)
    //   - createdAt: timestamp (required, immutable)
    //   - guests: list of maps (optional, each map can have id, name, headCount, checked)
    //   - dishes: list of maps (optional)
    //   - otherItems: list of maps (optional)
    //   - expenses: list of maps (optional)
    //   - notes: string (optional)
    //   - suggestions: string (optional)
    //   - dishesLocked: boolean (optional)
    //   - otherItemsLocked: boolean (optional)
    //   - guestsLocked: boolean (optional)
    //   - showPaidCheckboxes: boolean (optional)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.ownerId;
    }

    function isValidPotluck(data) {
      return data.id is string &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.ownerId is string &&
             data.createdAt is timestamp &&
             (!('totalPeople' in data) || data.totalPeople is number) &&
             (!('description' in data) || (data.description is string && data.description.size() <= 2000)) &&
             (!('notes' in data) || (data.notes is string && data.notes.size() <= 5000)) &&
             (!('suggestions' in data) || (data.suggestions is string && data.suggestions.size() <= 5000)) &&
             (!('guests' in data) || data.guests is list) &&
             (!('dishes' in data) || data.dishes is list) &&
             (!('otherItems' in data) || data.otherItems is list) &&
             (!('expenses' in data) || data.expenses is list) &&
             (!('dishesLocked' in data) || data.dishesLocked is bool) &&
             (!('otherItemsLocked' in data) || data.otherItemsLocked is bool) &&
             (!('guestsLocked' in data) || data.guestsLocked is bool) &&
             (!('showPaidCheckboxes' in data) || data.showPaidCheckboxes is bool);
    }

    match /potlucks/{potluckId} {
      // Viewing does not require signin
      allow read: if true;

      // Create requires signin and ownerId must match auth.uid
      allow create: if isAuthenticated() && 
                      isValidPotluck(request.resource.data) &&
                      request.resource.data.ownerId == request.auth.uid;

      // Update does not require signin for public potlucks
      // We are more permissive on updates to avoid guest friction
      allow update: if (request.resource.data.ownerId == resource.data.ownerId) &&
                      (request.resource.data.createdAt == resource.data.createdAt);

      // Delete requires signin and must be the owner
      allow delete: if isAuthenticated() && isDocOwner();

    }
  }
}
